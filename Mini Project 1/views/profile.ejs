<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 py-10 px-5">
        <div class="flex justify-end w-full">
            <a href="/logout" class="bg-red-500 text-white rounded-md px-3 py-2 text-sm">Log out</a>

        </div>
        <h1 class="text-3xl text-white mb-2 mt-5">Hello <%= user.name %> 🙋‍♂️</h1>
        <h5 class="text-white mb-5">You can create a new post</h5>
        <form action="/post" method="post">
            <textarea placeholder="Write your thought" name="content" class="mb-4 block p-4 outline-none w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md text-white"></textarea>
            <input type="submit" class="bg-blue-500 block text-white px-4 py-2 rounded-md w-auto text-sm" value="Create your post">
        </form>
     <div class="mt-20 posts text-white">
        <h2 class="text-zinc-400">Your posts.</h2>
        <div class="postcontainer mt-4">
                <% user.posts.reverse().forEach(function(post){ %>

                 <div class="w-1/3 post p-4 border-2 border-zinc-800 bg-zinc-800 rounded-md mb-4">
                <h4 class="text-blue-500 mb-2"><%= user.username %></h4>
                <p class="text-sm tracking-tight"><%= post.content %></p>
                <div class="btns flex mt-5 gap-4">
                    <a href=""class="text-blue-500">Like</a>
                    <a href=""class="text-zinc-400">edit</a>
                </div>
            </div>

              <%  })%>
        </div>
     </div>
    </div>
</body>
</html>